<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Veterinarians</h1>
  <%= link_to "New Veterinarian", new_vet_path, class: "btn btn-primary" %> <!-- -->
</div>

<table class="table table-striped table-hover shadow-sm">
  <thead class="table-dark">
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Specialization</th>
      <th class="text-center">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @vets.each do |vet| %>
      <tr>
        <td><%= "#{vet.first_name} #{vet.last_name}" %></td>
        <td><%= vet.email %></td>
        <td><%= vet.specialization %></td>
        <td class="text-center">
          <div class="d-flex justify-content-center gap-1">
            <%= link_to "View Profile", vet_path(vet), class: "btn btn-sm btn-outline-primary" %> <!-- -->
            <%= link_to "Edit", edit_vet_path(vet), class: "btn btn-sm btn-info" %> <!-- -->
            <%= button_to "Delete", vet_path(vet), method: :delete, 
                data: { turbo_confirm: "Are you sure?" }, 
                class: "btn btn-sm btn-danger", form_class: "d-inline" %> <!-- -->
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
