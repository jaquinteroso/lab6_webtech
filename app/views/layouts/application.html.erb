<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Vet Clinic" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# 1. Agregamos Bootstrap vía CDN antes que nuestros estilos %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <%# 2. Renderizamos la barra de navegación (partial) %>
    <%= render 'layouts/navbar' %>

    <%# 3. Envolvemos el contenido en un contenedor de Bootstrap para que no toque los bordes %>
    <main class="container mt-4">
      <%= render 'layouts/flash' %>
      <%= yield %>
    </main>

    <%# JS de Bootstrap (opcional para componentes interactivos) %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
